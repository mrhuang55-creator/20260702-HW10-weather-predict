# ============================================================
# AI 智慧天氣預報系統 — 環境變數公開範本
#
# ⚠️ 本檔案（.env）為公開範本，不包含任何真實金鑰，可安全上傳 GitHub。
#
# 本機執行設定方式：
#   1. 複製本檔案，重新命名為 env.private（已加入 .gitignore）
#   2. 在 env.private 中填入您的真實 API Key
#   3. 程式啟動時會優先讀取 env.private，若不存在則 fallback 至本檔案
# ============================================================

# ── 中央氣象署 (CWA) 開放資料授權碼 ──────────────────────
# 申請網址：https://opendata.cwa.gov.tw/user/authkey
CWA_API_KEY=YOUR_CWA_API_KEY_HERE

# ── OpenAI API Key ─────────────────────────────────────────
# 申請網址：https://platform.openai.com/api-keys
# 若不填寫，系統會自動切換至本地規則引擎生成建議（不影響執行）
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# ── Flask 運行設定 ──────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# ── SSL 驗證開關 ────────────────────────────────────────────
# 開發環境（Windows 本機）設為 true 可繞過憑證問題
# 正式部署請改為 false
DISABLE_SSL_VERIFY=true
